{
  "openapi": "3.0.0",
  "info": {
    "title": "LUFACE API",
    "description": "Biometric Face Recognition and Identity Management Platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Current Environment"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "paths": {
    "/api/v1/register": {
      "post": {
        "summary": "Register a new external user with a face descriptor",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "faceDescriptor": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    },
                    "description": "A single face descriptor array (128 or 512 numbers)"
                  }
                },
                "required": [
                  "email",
                  "faceDescriptor"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "description": "Invalid API Key"
          }
        }
      }
    },
    "/api/v1/identify": {
      "post": {
        "summary": "Identify a user based on a face descriptor",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "description": "The target identifier to check against"
                  },
                  "faceDescriptor": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                },
                "required": [
                  "email",
                  "faceDescriptor"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Match result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "match": {
                      "type": "boolean"
                    },
                    "username": {
                      "type": "string",
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
